## Faz 8 — Netlify Özel Yapılandırma

#### [NEW] `netlify.toml` (proje kökünde oluşturulacak)

```toml
[build]
  publish = "."

# www → non-www yönlendirme
[[redirects]]
  from = "https://www.ysfyachting.com/*"
  to = "https://ysfyachting.com/:splat"
  status = 301
  force = true

# Custom 404
[[redirects]]
  from = "/*"
  to = "/404.html"
  status = 404

# Güvenlik ve cache headers
[[headers]]
  for = "/*"
  [headers.values]
    X-Frame-Options = "DENY"
    X-Content-Type-Options = "nosniff"
    Referrer-Policy = "strict-origin-when-cross-origin"

[[headers]]
  for = "/assets/*"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

[[headers]]
  for = "/css/*"
  [headers.values]
    Cache-Control = "public, max-age=604800"

[[headers]]
  for = "/js/*"
  [headers.values]
    Cache-Control = "public, max-age=604800"
```

